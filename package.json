{
  "name": "opencontext-promptless",
  "version": "1.4.0",
  "description": "Extract Figma designs into AI-ready context packages so your AI can understand your designs better",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode ui & vite build --watch --mode code",
    "build": "tsc --noEmit && vite build --mode ui && vite build --mode code",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm build && pnpm verify",
    "preview:ui": "pnpm build && node scripts/preview-ui.mjs"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@figma/plugin-typings": "^1.109.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.0",
    "vite-plugin-singlefile": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.4"
}
